# RoleLens environment template (minimal)
# Copy this file to `.env.local` and fill only what you need:
#   cp .env.example .env.local

# Required for production auth security.
# Use a long random value (example: `openssl rand -base64 48`).
AUTH_PASSWORD_PEPPER=

# Feed source URL for deployed sync/import.
# Local development can run without this (local fallback is used).
PYTHON_SCRAPED_FEED_URL=

# Required only if you use /api/jobs/cron automation.
CRON_SECRET=

# Optional backend override (blank = auto/default behavior).
PERSISTENCE_BACKEND=
AUTH_BACKEND=
