# RoleLens local development environment
# Copy this file to `.env.local` and adjust values as needed.
#
# Quick start:
#   cp .env.example .env.local
#   npm run dev        # Next.js local runtime (memory default)
#   npm run dev:d1     # Cloudflare local runtime (D1 via wrangler.toml)

# Feed source configuration
# Python crawler JSON feed is the primary/only ingestion path.

# Python scraping feed
# Example:
# PYTHON_SCRAPED_FEED_URL=https://raw.githubusercontent.com/<owner>/<repo>/main/data/scraped/python-scraped-jobs.json
# Local dev note: when this is empty, /api/jobs/import falls back to /api/jobs/local-python-scraped-feed.
PYTHON_SCRAPED_FEED_URL=
PYTHON_SCRAPED_SOURCE_LABEL=Python Scraper
PYTHON_SCRAPED_SOURCE_TYPE=MANUAL
PYTHON_SCRAPED_DEFAULT_COMPANY=

# Optional filter tuning for local dev
TARGET_ROLE_KEYWORDS=frontend,front-end,react,typescript,software engineer
TARGET_LOCATION_KEYWORDS=canada,toronto,vancouver,montreal,ottawa,korea,seoul,remote,united states,usa

# Cron auth (used by /api/jobs/cron)
CRON_SECRET=local-dev-cron-secret

# Public sync hardening
# In production, keep ALLOW_PUBLIC_FEED_REFRESH=0 to block expensive manual refresh endpoints.
# For trusted server-side/manual refresh calls, send one of:
#   - x-rolelens-sync-secret: <SYNC_ADMIN_SECRET>
#   - x-cron-secret: <CRON_SECRET>
SYNC_ADMIN_SECRET=
ALLOW_PUBLIC_FEED_REFRESH=0
IMPORT_PUBLIC_RATE_LIMIT_PER_MIN=60

# Optional persistence PoC auth
PERSISTENCE_POC_TOKEN=


# Auth security (required in production)
# Use a long random value (example: `openssl rand -base64 48`).
# Format must be KEY=VALUE, e.g. AUTH_PASSWORD_PEPPER=your-random-value
AUTH_PASSWORD_PEPPER=
