# RoleLens environment template (minimal)
# Copy this file to `.env.local` and fill only what you need:
#   cp .env.example .env.local

# Required for production auth security.
# Use a long random value (example: `openssl rand -base64 48`).
AUTH_PASSWORD_PEPPER=

# Feed ingestion backend:
# - d1: primary mode (read latest uploaded snapshot from D1)
# - url: compatibility mode (read hosted JSON from PYTHON_SCRAPED_FEED_URL)
PYTHON_SCRAPED_FEED_BACKEND=d1

# Optional only for URL mode.
# Local development can run without this (local fallback is used).
PYTHON_SCRAPED_FEED_URL=

# Optional D1 binding override for feed snapshots (default: DB).
SCRAPED_FEED_D1_BINDING=

# Cloudflare-native crawler controls (used by /api/jobs/scraped-feed/sync and /api/jobs/cron).
# Set SCRAPED_FEED_AUTO_CRAWL=0 to skip crawler run inside /api/jobs/cron.
SCRAPED_FEED_AUTO_CRAWL=1
SCRAPED_FEED_TIMEOUT_SECONDS=20
SCRAPED_FEED_LIMIT_PER_SOURCE=120
SCRAPED_FEED_CRAWL_CONCURRENCY=4

# Required only if you use /api/jobs/cron automation.
CRON_SECRET=

# Optional backend override (blank = auto/default behavior).
PERSISTENCE_BACKEND=
AUTH_BACKEND=
