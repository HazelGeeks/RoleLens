{
  "name": "rolelens-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:cloudflare": "npm run db:schema:local && npm run pages:build && wrangler pages dev .vercel/output/static --persist-to .wrangler/state --port 3000 --env-file .env.local",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app components lib",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run lint && npm test",
    "cf:build": "npm run pages:build",
    "pages:build": "next build && npx @cloudflare/next-on-pages@1 && node scripts/patch-pages-routes.mjs",
    "pages:deploy": "wrangler pages deploy .vercel/output/static",
    "db:schema:local": "wrangler d1 migrations apply rolelens-db --local",
    "db:schema:preview": "wrangler d1 migrations apply rolelens-db --preview",
    "db:schema:prod": "wrangler d1 migrations apply rolelens-db --remote"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@mantine/core": "^7.17.8",
    "@tanstack/react-table": "^8.21.3",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "15.5.2",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.1",
    "recharts": "^3.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.2",
    "typescript": "^5",
    "vitest": "^3.2.4",
    "wrangler": "^4.81.1"
  }
}
